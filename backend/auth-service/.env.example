# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mankahi_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-secret-key-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Session
SESSION_SECRET="your-session-secret-at-least-32-chars"

# Service URLs
AUTH_SERVICE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW=900 # 15 minutes in seconds
RATE_LIMIT_MAX_REQUESTS=100

# OAuth (Google)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# CORS - comma-separated allowlist of Origin header values this service
# will accept. Browsers send Origin on POST/PUT/DELETE even for
# same-origin requests, so this must include the gateway's own address
# (nginx, :8080) - not just the frontend dev server's own port (:3000, for
# requests that bypass nginx entirely). Leave unset in development to
# allow any origin; must be set in any other NODE_ENV or all cross-origin
# requests are rejected.
CORS_ORIGIN="http://localhost:8080,http://localhost:3000"

# Cookie Settings
COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false # Set to true in production
