NODE_ENV=development
PORT=3003

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/mankahi_db?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=60
DASHBOARD_RATE_LIMIT_MAX=300

# CORS - comma-separated allowlist of origins allowed to call this service
# directly (cross-origin). Requests through the nginx gateway are
# same-origin and unaffected by this. Leave unset in development to allow
# any origin; must be set in any other NODE_ENV or all cross-origin
# requests are rejected.
CORS_ORIGIN="http://localhost:3000"
