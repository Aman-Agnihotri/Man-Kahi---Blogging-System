NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://[user]:[password]@postgres:5432/mankahi_db?schema=public

# JWT - must match the other services' JWT_SECRET exactly (they verify
# tokens issued by auth-service), and be at least 32 random characters.
JWT_SECRET="your-secret-key-at-least-32-chars"
JWT_EXPIRES_IN=1d

# Services
ANALYTICS_SERVICE_URL=http://analytics-service:3003

# Rate Limiting
ADMIN_RATE_LIMIT_WINDOW=900000
ADMIN_RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Metrics
METRICS_ENABLED=true
METRICS_PREFIX=admin_
METRICS_DEFAULT_LABELS={"service":"admin"}
METRICS_COLLECTION_INTERVAL=5000

# CORS - comma-separated allowlist of origins allowed to call this service
# directly (cross-origin). Requests through the nginx gateway are
# same-origin and unaffected by this. Leave unset in development to allow
# any origin; must be set in any other NODE_ENV or all cross-origin
# requests are rejected.
CORS_ORIGIN=http://localhost:3000
