NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://[user]:[password]@postgres:5432/mankahi_db?schema=public

# JWT - must match the other services' JWT_SECRET exactly (they verify
# tokens issued by auth-service), and be at least 32 random characters.
JWT_SECRET="your-secret-key-at-least-32-chars"
JWT_EXPIRES_IN=1d

# Services
ANALYTICS_SERVICE_URL=http://analytics-service:3003

# Rate Limiting
ADMIN_RATE_LIMIT_WINDOW=900000
ADMIN_RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Metrics
METRICS_ENABLED=true
METRICS_PREFIX=admin_
METRICS_DEFAULT_LABELS={"service":"admin"}
METRICS_COLLECTION_INTERVAL=5000

# CORS - comma-separated allowlist of Origin header values this service
# will accept. Browsers send Origin on POST/PUT/DELETE even for
# same-origin requests, so this must include the gateway's own address
# (nginx, :8080) - not just the frontend dev server's own port (:3000, for
# requests that bypass nginx entirely). Leave unset in development to
# allow any origin; must be set in any other NODE_ENV or all cross-origin
# requests are rejected.
CORS_ORIGIN=http://localhost:8080,http://localhost:3000
