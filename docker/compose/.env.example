# Node Environment
NODE_ENV=development

# Service Ports
AUTH_PORT=3001
BLOG_PORT=3002
ANALYTICS_PORT=3003
ADMIN_PORT=3004
FRONTEND_PORT=3000

# Database Configuration
# NOTE: DATABASE_URL below repeats these two values literally rather than
# referencing them via ${VAR}. Docker Compose's `env_file:` does not expand
# ${VAR} references to other variables in the same file (that only works
# for variables interpolated directly into docker-compose.yml itself) -
# every service would otherwise receive a DATABASE_URL containing the
# literal text "${POSTGRES_USER}" instead of its actual value, and fail to
# connect. If you change POSTGRES_USER/POSTGRES_PASSWORD below, update
# DATABASE_URL to match (a find-and-replace across this file works, since
# the same placeholder text is reused verbatim in both places).
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=mankahi_db

# Redis Configuration
REDIS_URL=redis://redis:6379

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your_session_secret_key

# OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://auth-service:3001
BLOG_SERVICE_URL=http://blog-service:3002
ANALYTICS_SERVICE_URL=http://analytics-service:3003
ADMIN_SERVICE_URL=http://admin-service:3004
# Unlike the *_SERVICE_URL vars above (server-to-server, so the internal
# Docker hostname is correct), this is used to build browser-facing links
# (OAuth redirect, password reset email) - it must be an address the
# user's actual browser can reach, not the internal container hostname.
FRONTEND_URL=http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
DASHBOARD_RATE_LIMIT_MAX=1000
ADMIN_RATE_LIMIT_WINDOW=900000
ADMIN_RATE_LIMIT_MAX=50

# Blog Service Configuration
BLOG_CACHE_TTL=3600
SEARCH_CACHE_TTL=1800
ANALYTICS_CACHE_TTL=1800
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif

# Elasticsearch Configuration
# ELASTICSEARCH_URL must be the Docker service name (not localhost) - blog-
# service runs in its own container, where "localhost" means itself, not
# the elasticsearch container. Without this set, blog-service falls back to
# a http://localhost:9200 default and fails to start entirely.
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password
ELASTICSEARCH_INDEX_SHARDS=1
ELASTICSEARCH_INDEX_REPLICAS=1

# MinIO Configuration
# Same reasoning as ELASTICSEARCH_URL above: must be the Docker service
# name, not localhost, or cover-image uploads fail silently at request time.
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_REGION=ap-south-1

# Database URL - keep the user:password in sync with POSTGRES_USER/
# POSTGRES_PASSWORD above by hand (see the note there).
DATABASE_URL=postgresql://your_postgres_user:your_secure_password@postgres:5432/mankahi_db

# Logging
LOG_LEVEL=info

# CORS Configuration - comma-separated allowlist of Origin header values.
# Must include the nginx gateway's own address (:8080) - browsers send
# Origin on POST/PUT/DELETE even for same-origin requests through the
# gateway, not just the frontend dev server's own port (:3000, for
# requests that bypass nginx). Leaving it unset only works when
# NODE_ENV=development.
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Docker Build Configuration
DOCKER_REGISTRY=local
DOCKER_TAG=latest

# Metrics
# Every service's /metrics route 404s unless this is set (see
# backend/shared/config/metrics.ts's metricsEnabled gate) - without it,
# Prometheus's scrape targets stay permanently down and Grafana has
# nothing to show, with no error beyond a silent 404 on each scrape.
ENABLE_METRICS=true
