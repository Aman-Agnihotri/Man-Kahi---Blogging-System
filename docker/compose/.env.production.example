# Production environment template for docker-compose.prod.yml.
# Copy this file to .env.production or .env and replace every placeholder before use.

# Runtime
NODE_ENV=production
PUBLIC_APP_URL=https://your-domain.com
SITE_URL=https://your-domain.com
CORS_ORIGIN=https://your-domain.com

# Service ports inside Docker networks
AUTH_PORT=3001
BLOG_PORT=3002
ANALYTICS_PORT=3003
ADMIN_PORT=3004
FRONTEND_PORT=3000

# PostgreSQL
POSTGRES_USER=mankahi_prod_user
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=mankahi_db
DATABASE_URL=postgresql://mankahi_prod_user:replace-with-a-long-random-password@postgres:5432/mankahi_db?schema=public

# Redis
REDIS_URL=redis://redis:6379
REDIS_NODES=redis:6379

# JWT and sessions
JWT_SECRET=replace-with-at-least-64-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=replace-with-at-least-64-random-characters

# OAuth
# Leave blank to disable Google OAuth until credentials are configured.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# Internal service URLs
AUTH_SERVICE_URL=http://auth-service:3001
BLOG_SERVICE_URL=http://blog-service:3002
ANALYTICS_SERVICE_URL=http://analytics-service:3003
ADMIN_SERVICE_URL=http://admin-service:3004
FRONTEND_URL=https://your-domain.com

# Rate limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100
DASHBOARD_RATE_LIMIT_MAX=1000
ADMIN_RATE_LIMIT_WINDOW=900000
ADMIN_RATE_LIMIT_MAX=50

# Blog service
BLOG_CACHE_TTL=3600
SEARCH_CACHE_TTL=300
ANALYTICS_CACHE_TTL=1800
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif
UPLOAD_PATH=/app/blog-service/uploads

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_SHARDS=3
ELASTICSEARCH_INDEX_REPLICAS=0

# MinIO
MINIO_ROOT_USER=replace-with-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# Observability
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace-with-a-long-random-password
LOG_LEVEL=info

# Docker image metadata
DOCKER_REGISTRY=local
DOCKER_TAG=latest
